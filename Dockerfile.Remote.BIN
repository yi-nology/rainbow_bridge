# syntax=docker/dockerfile:1

##
## Build configuration
##
ARG BINARY_ARTIFACT_URL
ARG TARGETOS=linux
ARG TARGETARCH=amd64

##
## Binary artifact stage
##
FROM debian:bookworm-slim AS binary-artifact

ARG BINARY_ARTIFACT_URL

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    wget \
    tar \
    unzip && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /artifact

RUN if [ -n "$BINARY_ARTIFACT_URL" ]; then \
      wget -O artifact.tar.gz "$BINARY_ARTIFACT_URL" 2>/dev/null && \
      tar -xzf artifact.tar.gz --strip-components=1 2>/dev/null || \
      echo "Failed to download or extract binary artifact, exiting"; \
    else \
      echo "BINARY_ARTIFACT_URL not set, exiting"; \
      exit 1; \
    fi

##
## App runtime stage (target: app)
## Full application with embedded frontend
##
FROM debian:bookworm-slim AS app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    wget && \
    rm -rf /var/lib/apt/lists/*

RUN useradd --system --create-home --uid 10001 rainbow

WORKDIR /app

# 从binary-artifact阶段复制预构建的二进制文件和前端文件
COPY --from=binary-artifact /artifact/app /app/server
COPY --from=binary-artifact /artifact/web /app/web
COPY --from=binary-artifact /artifact/config.yaml /app/config.yaml

RUN mkdir -p /app/data/uploads /var/lib/rainbow_bridge && chown -R rainbow:rainbow /app /var/lib/rainbow_bridge

USER rainbow

EXPOSE 8080

ENTRYPOINT ["/app/server"]
CMD ["--config", "/app/config.yaml"]
